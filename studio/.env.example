# Sanity Studio reads SANITY_STUDIO_* env vars at build/runtime.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
# Optional: the subdomain for `npx sanity deploy` -> <host>.sanity.studio
SANITY_STUDIO_HOST=speechworks-blog
# Comma-separated emails allowed to Approve + Publish. Kept here (gitignored .env),
# not in source, so editor emails stay out of the public repo. e.g. a@x.com,b@y.com
SANITY_STUDIO_EDITORS=

# --- Presentation (visual editing) ---
# The blog origin the Presentation tool previews against. Local: http://localhost:3000
SANITY_STUDIO_PREVIEW_URL=https://blog.speechworks.app
