# --- Database (Neon Postgres) ---
# Use the POOLED connection string (host contains "-pooler"), ending ?sslmode=require.
DATABASE_URI=

# --- Payload secret ---
# Master key Payload uses to sign login sessions. Any long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=
# (Draft preview is gated by the logged-in admin session — no preview secret needed.)

# --- Media storage (Cloudflare R2, S3-compatible) ---
# Optional locally (uploads fall back to local disk); required in production.
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Site URLs ---
# This blog's OWN origin — drives canonical URLs, OG tags, the sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://blog.speechworks.app
# The marketing site origin — shared-chrome assets (logo) + nav/footer back-links.
NEXT_PUBLIC_MARKETING_URL=https://speechworks.app
# Empty for the blog.speechworks.app subdomain (routes live at the root).
NEXT_PUBLIC_BASE_PATH=

# --- Private package install (@speech-works/web-chrome via GitHub Packages) ---
# A GitHub PAT with read:packages — set in your shell / CI, never committed.
# NODE_AUTH_TOKEN=
