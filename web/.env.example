# Sanity project the blog reads from (Content API). Find these in sanity.io/manage.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# API version pin (date). Bump intentionally when you adopt new API features.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# This blog's OWN origin — drives canonical URLs, OG tags, the sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://blog.speechworks.app
# The marketing site origin — shared-chrome assets (logo) + nav/footer back-links.
NEXT_PUBLIC_MARKETING_URL=https://speechworks.app

# Empty for the blog.speechworks.app subdomain (routes live at the root).
NEXT_PUBLIC_BASE_PATH=

# Shared secret the Sanity publish webhook must present to /api/revalidate.
SANITY_REVALIDATE_SECRET=

# --- Visual editing / draft preview ---
# A Sanity read token (Viewer). Create at sanity.io/manage -> API -> Tokens.
# Server-only — never expose. Required to render drafts + the Live Content API.
SANITY_API_READ_TOKEN=
# Where the Studio is hosted (used by stega so overlays deep-link into the Studio).
# Local testing: http://localhost:3333
NEXT_PUBLIC_SANITY_STUDIO_URL=https://speechworks-blog.sanity.studio
